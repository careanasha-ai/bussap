{
  "name": "crestline",
  "version": "1.0.0",
  "description": "Crestline - Shopify Business Intelligence App",
  "scripts": {
    "dev": "shopify app dev",
    "build": "remix vite:build",
    "start": "remix-serve ./build/server/index.js",
    "setup": "prisma generate && prisma migrate deploy",
    "postinstall": "prisma generate",
    "docker-start": "npm run setup && npm run build && npm run start",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate"
  },
  "type": "module",
  "engines": {
    "node": ">=18.20.0"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "@remix-run/node": "^2.13.1",
    "@remix-run/react": "^2.13.1",
    "@remix-run/serve": "^2.13.1",
    "@shopify/app-bridge-react": "^4.1.6",
    "@shopify/polaris": "^13.9.2",
    "@shopify/shopify-app-remix": "^3.4.0",
    "@shopify/shopify-app-session-storage-prisma": "^5.1.4",
    "isbot": "^5.1.17",
    "openai": "^4.67.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.3",
    "vite-tsconfig-paths": "^5.1.3"
  },
  "devDependencies": {
    "@remix-run/dev": "^2.13.1",
    "@shopify/cli": "^3.70.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "prisma": "^5.20.0",
    "vite": "^5.4.11"
  }
}