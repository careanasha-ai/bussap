# Shopify App Credentials (from Shopify Partner Dashboard)
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret

# App URL (your Railway deployment URL)
SHOPIFY_APP_URL=https://your-app.railway.app

# Database (auto-provided by Railway PostgreSQL plugin)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Session encryption secret (generate with: openssl rand -hex 32)
SESSION_SECRET=your_super_secret_session_key_here

# OpenAI API Key (for AI insights and NL queries)
OPENAI_API_KEY=sk-your-openai-api-key

# Node environment
NODE_ENV=production

# Port (Railway sets this automatically)
PORT=3000