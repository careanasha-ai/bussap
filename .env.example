# ─────────────────────────────────────────────────────────
# Shopify App Credentials (from Shopify Partner Dashboard)
# ─────────────────────────────────────────────────────────
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret

# App URL (your Railway deployment URL — no trailing slash)
SHOPIFY_APP_URL=https://your-app.railway.app

# Shopify access scopes (copy exactly)
SCOPES=read_orders,read_products,read_customers,read_reports,read_inventory,read_analytics,read_marketing_events,read_shipping,read_discounts

# ─────────────────────────────────────────────────────────
# Database (auto-provided by Railway PostgreSQL plugin)
# DO NOT set manually — Railway injects this automatically
# ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─────────────────────────────────────────────────────────
# Session Security
# Generate with: openssl rand -hex 32
# ─────────────────────────────────────────────────────────
SESSION_SECRET=your_super_secret_session_key_minimum_32_chars

# ─────────────────────────────────────────────────────────
# OpenAI (for AI insights, AI Advisor, NL queries)
# Get key at: https://platform.openai.com/api-keys
# ─────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key

# ─────────────────────────────────────────────────────────
# Email Reports (Resend — free tier: 3,000 emails/month)
# Sign up at: https://resend.com (no credit card required)
# ─────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=reports@yourdomain.com

# ─────────────────────────────────────────────────────────
# Node environment
# ─────────────────────────────────────────────────────────
NODE_ENV=production

# Port (Railway sets this automatically — do not change)
PORT=3000